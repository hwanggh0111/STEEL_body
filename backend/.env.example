PORT=4000
NODE_ENV=development
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING_MIN_64_CHARS
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
ADMIN_EMAIL=admin@example.com

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# SMTP (비밀번호 재설정 / 인증번호 발송)
# 미설정 시: 개발 모드는 응답 body로 인증번호 노출, 프로덕션은 발송 실패
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=STEEL BODY <noreply@steelbody.app>
